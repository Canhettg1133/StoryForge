## Pronoun Presets bổ sung

```javascript
// Thêm vào PRONOUN_PRESETS
tien_hiep: {
  label: 'Tiên hiệp',
  options: ['tại hạ', 'ta', 'bản tọa', 'bản nhân', 'đạo hữu', 'tiền bối', 
            'sư huynh', 'sư đệ', 'sư muội', 'lão phu', 'ngươi', 'các hạ',
            'sư tổ', 'chưởng môn', 'trưởng lão'],
  default_self: 'tại hạ',
  default_other: 'đạo hữu',
},

// Thêm vào GENRE_PRONOUN_MAP
tien_hiep: 'tien_hiep',  // (hoặc dùng 'fantasy' nếu đủ)
huyen_huyen: 'fantasy',
he_thong: 'modern',
mat_the: 'modern',
ngon_tinh_cd: 'co_dai',
dam_my: 'modern',        // dynamic — tùy bối cảnh cổ đại/hiện đại
```

