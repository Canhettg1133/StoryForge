{
  "name": "storyforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "db:start": "powershell -ExecutionPolicy Bypass -File scripts/start-local-postgres.ps1",
    "db:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-postgres.ps1",
    "backend:start": "powershell -ExecutionPolicy Bypass -File scripts/start-local-backend.ps1",
    "jobs:server": "node src/services/jobs/server.js",
    "analysis:eval:live": "node scripts/analysis-live-eval.mjs",
    "test": "vitest run",
    "test:phase6b": "vitest run src/tests/phases/phase6b-incidentFirst.test.js",
    "test:phase6d": "vitest run src/tests/phases/phase6d-analysisV2.test.js",
    "test:phase6f": "vitest run src/tests/phases/phase6f-analysisLiveEval.test.js",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tiptap/extension-character-count": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "@vercel/speed-insights": "^2.0.0",
    "cors": "^2.8.6",
    "dexie": "^4.0.0",
    "dexie-react-hooks": "^1.1.7",
    "docx": "^9.6.1",
    "epubjs": "^0.3.93",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.5.10",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.0.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
